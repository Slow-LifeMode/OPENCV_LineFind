<Window x:Class="OpenCvWindowToolWpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenCvWindowToolWpfDemo"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="OpenCV 直线检测算子"
        Width="1320"
        Height="860"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ModuleButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="10,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,4" />
            <Setter Property="Foreground" Value="#444444" />
        </Style>
    </Window.Resources>
    <Grid Background="#F4F5F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#20242A">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="直线检测"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="16,18,16,14" />
                <StackPanel>
                    <Button x:Name="InputModuleButton" Content="输入图像" Style="{StaticResource ModuleButtonStyle}" Click="InputModule_Click" />
                    <Button x:Name="RoiModuleButton" Content="ROI" Style="{StaticResource ModuleButtonStyle}" Click="RoiModule_Click" />
                    <Button x:Name="ParamsModuleButton" Content="参数设置" Style="{StaticResource ModuleButtonStyle}" Click="ParamsModule_Click" />
                    <Button x:Name="ResultModuleButton" Content="结果输出" Style="{StaticResource ModuleButtonStyle}" Click="ResultModule_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="ViewerBorder" Grid.Column="1" Margin="10" Background="Black" BorderBrush="#D7DCE2" BorderThickness="1">
            <wfi:WindowsFormsHost x:Name="FormsHost" />
        </Border>

        <Border Grid.Column="2" Background="White" BorderBrush="#D7DCE2" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="18">
                    <StackPanel x:Name="InputPanel">
                        <TextBlock Text="输入图像" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="导入待检测图像后，中间区域会显示当前图像。" TextWrapping="Wrap" Foreground="#555555" />
                        <Button Content="导入图像" Style="{StaticResource ActionButtonStyle}" Click="OpenImage_Click" />
                        <TextBlock x:Name="ImageStatusTextBlock" Margin="0,12,0,0" Foreground="#666666" Text="未导入图像" />
                    </StackPanel>

                    <StackPanel x:Name="RoiPanel" Visibility="Collapsed">
                        <TextBlock Text="ROI" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="创建检测区域后，可在中间图像上拖动、缩放或旋转ROI。" TextWrapping="Wrap" Foreground="#555555" />
                        <Button Content="创建矩形检测ROI" Style="{StaticResource ActionButtonStyle}" Click="CreateRectangleRoi_Click" />
                        <Button Content="创建带角度矩形ROI" Style="{StaticResource ActionButtonStyle}" Click="CreateRotatedRectangleRoi_Click" />
                        <Button Content="清除ROI" Style="{StaticResource ActionButtonStyle}" Click="ClearRoi_Click" />
                        <TextBlock x:Name="RoiStatusTextBlock" Margin="0,12,0,0" Foreground="#666666" Text="未创建ROI" />
                    </StackPanel>

                    <StackPanel x:Name="ParamsPanel" Visibility="Collapsed">
                        <TextBlock Text="参数设置" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock Text="ROI检测方向" Style="{StaticResource FieldLabelStyle}" />
                        <UniformGrid Columns="4">
                            <ToggleButton x:Name="LeftToRightButton" Content="→" Height="36" Margin="0,0,4,0" Click="DirectionButton_Click" />
                            <ToggleButton x:Name="TopToBottomButton" Content="↓" Height="36" Margin="0,0,4,0" Click="DirectionButton_Click" />
                            <ToggleButton x:Name="BottomToTopButton" Content="↑" Height="36" Margin="0,0,4,0" Click="DirectionButton_Click" />
                            <ToggleButton x:Name="RightToLeftButton" Content="←" Height="36" Click="DirectionButton_Click" />
                        </UniformGrid>

                        <TextBlock Text="ROI边缘极性" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="PolarityComboBox" SelectionChanged="Parameter_Changed" />

                        <TextBlock Text="边缘选择" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="SelectionModeComboBox" SelectionChanged="Parameter_Changed" />

                        <TextBlock Text="拟合直线方式" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="FitModeComboBox" SelectionChanged="Parameter_Changed" />

                        <TextBlock Text="边缘强度类型" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="StrengthTypeComboBox" SelectionChanged="Parameter_Changed" />

                        <TextBlock Text="边缘阈值" Style="{StaticResource FieldLabelStyle}" />
                        <local:NumericInputBox x:Name="ThresholdInput"
                                               Value="20"
                                               Minimum="0"
                                               Maximum="1000"
                                               Increment="1"
                                               ValueKind="Float"
                                               ValueChanged="Parameter_Changed" />

                        <TextBlock Text="检测点个数" Style="{StaticResource FieldLabelStyle}" />
                        <local:NumericInputBox x:Name="SampleCountInput"
                                               Value="40"
                                               Minimum="2"
                                               Maximum="500"
                                               Increment="1"
                                               ValueKind="Integer"
                                               ValueChanged="Parameter_Changed" />

                        <Border Margin="0,16,0,0" Padding="10" Background="#F7F8FA" BorderBrush="#E1E5EA" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="检测结果" FontWeight="SemiBold" />
                                <TextBlock x:Name="LiveStatusTextBlock" Text="未检测" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock x:Name="LiveLineTextBlock" Text="-" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="ResultPanel" Visibility="Collapsed">
                        <TextBlock Text="结果输出" Style="{StaticResource PanelTitleStyle}" />
                        <TextBlock x:Name="ResultStatusTextBlock" Text="未检测" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock x:Name="ResultStartTextBlock" Margin="0,12,0,0" Text="起点: -" />
                        <TextBlock x:Name="ResultEndTextBlock" Margin="0,8,0,0" Text="终点: -" />
                        <TextBlock x:Name="ResultAngleTextBlock" Margin="0,8,0,0" Text="角度: -" />
                        <TextBlock x:Name="ResultPointCountTextBlock" Margin="0,8,0,0" Text="检测点数: -" />
                        <TextBlock x:Name="ResultAverageStrengthTextBlock" Margin="0,8,0,0" Text="平均边缘强度: -" />
                        <TextBlock x:Name="ResultMaxStrengthTextBlock" Margin="0,8,0,0" Text="最大边缘强度: -" />
                        <TextBlock x:Name="ResultDirectionTextBlock" Margin="0,8,0,0" Text="检测方向: -" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
